{
    "cli": {
        "version": ">= 18.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "development-simulator": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "distribution": "internal"
        },
        "testflight": {
            "distribution": "store",
            "channel": "testflight",
            "ios": {
                "buildConfiguration": "Release"
            }
        },
        "production": {
            "autoIncrement": true
        }
    }
}