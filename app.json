{
  "expo": {
    "name": "PadPal",
    "slug": "padpal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "padpal",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.markus.padpal",
      "infoPlist": {
        "NSCameraUsageDescription": "PadPal needs camera access to take photos of chores and receipts for verification.",
        "NSPhotoLibraryUsageDescription": "PadPal needs photo library access to upload chore and receipt photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.markus.padpal",
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "PadPal needs camera access for chore verification photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PadPal needs photo access to upload receipt and chore images."
        }
      ],
      "expo-build-properties"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50cfb2bc-acfe-4ce8-9a41-e86bf44d2ac8"
      }
    },
    "owner": "markusd"
  }
}
